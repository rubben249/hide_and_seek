# ============================================================
# TAG! — The Playground Chase — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- REQUIRED ----
# Password required to connect to the online mode WebSocket.
# Share this with your friends. Keep it private.
SERVER_PASSWORD=change_me_before_deploying

# ---- OPTIONAL ----
# Port the server listens on
PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8000

# Maximum number of concurrent online game rooms
MAX_ROOMS=50

# Max failed auth attempts per IP per minute before rate-limiting
AUTH_RATE_LIMIT=5

# How long a session token remains valid (minutes)
SESSION_TIMEOUT_MINUTES=120

# Seconds before WS closes if no auth message received
WS_AUTH_TIMEOUT=5

# Seconds of inactivity before a room is auto-closed
ROOM_IDLE_TIMEOUT=1800

# ---- GAME BOARD CONSTANTS ----
BOARD_SIZE=24
HAND_SIZE_LIMIT=4
DEFAULT_MAX_DISCARDS=4
TEAM_2V1_DISCARD_PER_MEMBER=2
TEAM_2V1_DISCARD_SOLO=4

# ---- GAME TIMERS (all in seconds) ----
# Total game duration limit
GAME_TIME_LIMIT=1800

# Per-player cumulative time limit
PLAYER_TIME_LIMIT=900

# Per-turn time limit
TURN_TIME_LIMIT=120

# Show visual countdown when ≤ this many seconds remain in a turn
TURN_COUNTDOWN_THRESHOLD=30

# Seconds to wait for turn_ready signal (animation grace) before auto-starting clock
ANIMATION_GRACE_SECONDS=6

# Comma-separated fractions of PLAYER_TIME_LIMIT at which to send a warning
PLAYER_WARNING_FRACTIONS=0.25,0.5,0.75

# ---- USER ACCOUNTS (JWT) ----
# Secret key for signing JWT tokens. Generate a strong random value.
JWT_SECRET=change_jwt_secret_before_deploying

# How long a JWT access token remains valid (hours). Default: 720 = 30 days
JWT_EXPIRE_HOURS=720

# SQLite database file path (relative to /app in container)
DATABASE_URL=sqlite+aiosqlite:///./tag_game.db
